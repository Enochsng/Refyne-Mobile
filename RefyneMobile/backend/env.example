# =============================================================================
# Refyne backend — environment variables
# Copy to .env on the server and fill in values. Never commit .env.
# =============================================================================

# --- Docker / compose (optional) ---
# Full image reference pushed by GitHub Actions to GHCR (lowercase owner).
# BACKEND_IMAGE=ghcr.io/your-github-username/refyne-backend:latest

# --- Server ---
PORT=3001
NODE_ENV=production

# --- Stripe (required) ---
STRIPE_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Connect (if using Connect onboarding)
STRIPE_CONNECT_CLIENT_ID=ca_xxx
STRIPE_CONNECT_REDIRECT_URI=https://your-api-domain/auth/stripe/callback

# Platform fee (percentage, default in code is 15 if unset)
PLATFORM_FEE_PERCENTAGE=10

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- App URLs ---
# Public base URL of this API (used for Stripe return URLs, etc.)
APP_URL=https://your-api-domain
APP_NAME=Refyne Mobile Backend

# --- CORS ---
# Comma-separated origins allowed in production
ALLOWED_ORIGINS=https://your-app.example,exp://your-app.example

# --- Optional ---
# DATABASE_URL=  # if you add a direct DB connection later
