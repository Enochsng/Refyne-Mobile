# =============================================================================
# Refyne backend — environment variables
# Copy to .env on the server and fill in values. Never commit .env.
# =============================================================================

# --- Docker (VPS / compose) ---
# Required for docker-compose.yaml (GHCR image from CI or a local tag).
BACKEND_IMAGE=ghcr.io/your-github-username-lowercase/refyne-backend:latest

# --- Server ---
PORT=3001
NODE_ENV=production

# --- Stripe (required) ---
STRIPE_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Connect (if using Connect onboarding)
STRIPE_CONNECT_CLIENT_ID=ca_xxx
STRIPE_CONNECT_REDIRECT_URI=https://your-api-domain/auth/stripe/callback

# Platform fee (percentage, default in code is 15 if unset)
PLATFORM_FEE_PERCENTAGE=10

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- App URLs ---
# Public base URL of this API (used for Stripe return URLs, etc.)
APP_URL=https://your-api-domain
APP_NAME=Refyne Mobile Backend

# --- CORS ---
# React Native / Expo (native) requests usually send NO Origin header — the API allows that,
# so you do NOT need a special "mobile app URL" for typical in-app fetch/axios calls.
# Set ALLOWED_ORIGINS only if you use Expo Web, a browser, or a WebView that sends Origin:
#   ALLOWED_ORIGINS=https://your-expo-web-host,http://localhost:19006
# Leave unset to use the built-in fallback list in server.js, or set a tight list for web-only.
ALLOWED_ORIGINS=

# --- Easiest RackNerd deploy ---
# 1) Copy docker-compose.yaml + this file as .env onto the VPS (same directory).
# 2) In .env set BACKEND_IMAGE=ghcr.io/<your-github-user-lowercase>/refyne-backend:latest
#    and APP_URL=https://api.yourdomain.com (match Caddy / your TLS host).
# 3) docker login ghcr.io (PAT with read:packages) then: docker compose pull && docker compose up -d
# 4) Install Caddy on the host; use Caddyfile.example so TLS terminates on :443 → 127.0.0.1:3001
#    (compose publishes 3001 on loopback only — open 80/443 in the firewall for Caddy).
#
# Optional: GitHub self-hosted runner on the VPS — see .github/workflows/deploy.yml

# --- Optional ---
# DATABASE_URL=  # if you add a direct DB connection later
